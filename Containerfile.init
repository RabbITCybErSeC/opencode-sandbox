# Strict init image for opencode-sandbox eBPF policy daemon.
# Apple container custom init images must wrap the default vminitd binary.
# The wrapper starts policy-ebpfd when runtime state is mounted, then execs
# the real vminitd so the lightweight VM can continue normal startup.

ARG GO_VERSION=1.26
ARG VMINIT_IMAGE=ghcr.io/apple/containerization/vminit:0.31.0
FROM golang:${GO_VERSION}-bookworm AS builder

WORKDIR /build
COPY go.mod go.sum ./
COPY cmd/policy-ebpfd ./cmd/policy-ebpfd
COPY cmd/vminit-wrapper ./cmd/vminit-wrapper
COPY internal/audit ./internal/audit
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o policy-ebpfd ./cmd/policy-ebpfd \
    && CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o vminit-wrapper ./cmd/vminit-wrapper

# ---

FROM ${VMINIT_IMAGE} AS vminit

# ---

FROM ${VMINIT_IMAGE}

LABEL org.opencontainers.image.source="https://github.com/RabbITCybErSeC/opencode-sandbox"

COPY --from=vminit /sbin/vminitd /sbin/vminitd.real
COPY --from=builder /build/policy-ebpfd /usr/local/bin/policy-ebpfd
COPY --from=builder /build/vminit-wrapper /sbin/vminitd
